load("@io_bazel_rules_docker//container:container.bzl", "container_image", "container_layer")

package(default_visibility = [
    "//src/carnot:__subpackages__",
    "//src/stirling:__subpackages__",
])

# ClickHouse configuration layer for console logging
container_layer(
    name = "clickhouse_config_layer",
    directory = "/etc/clickhouse-server/config.d",
    files = ["clickhouse_logging_config.xml"],
    mode = "0644",
)

container_image(
    name = "clickhouse",
    base = "@clickhouse_server_base_image//image",
    layers = [":clickhouse_config_layer"],
    visibility = ["//visibility:public"],
)
